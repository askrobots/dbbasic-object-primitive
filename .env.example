# Object Primitive Server — environment configuration
#
# Copy this file to .env and adjust values. Only OBJPRIM_AUTH_PASS is required
# (and only in production mode); everything else has a safe default.

# development (default) or production. Production mode REQUIRES OBJPRIM_AUTH_PASS.
OBJPRIM_MODE=development

# Basic auth username (default: admin)
# OBJPRIM_AUTH_USER=admin

# Basic auth password. REQUIRED when OBJPRIM_MODE=production.
# Leave unset in development to disable auth entirely.
# OBJPRIM_AUTH_PASS=

# Requests per minute per IP. 0 disables rate limiting.
# OBJPRIM_RATE_LIMIT=1000

# Secret for tokens/sessions. Auto-generated per-process if unset.
# Set this explicitly in production so sessions survive restarts.
# OBJPRIM_SECRET_KEY=

# Optional URL that validates bearer tokens for an external auth service.
# OBJPRIM_AUTH_VERIFY_URL=
